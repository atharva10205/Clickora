generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id         String   @id @default(uuid())
  email      String   @unique
  name       String?
  created_at DateTime @default(now())
  role       String?
  image      String?
  accent     String?  @default("#FFFFFF")
}

model Ad {
  id              String   @id @default(uuid())
  business_name   String?
  destination_url String?
  Description     String?
  wallet_address  String?
  cost_per_click  Decimal? @db.Decimal(18, 9)
  user_email      String
  Tags            String[]
  keywords        String[]
  title           String?
  imageUrl        String?
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt
  Clicks          Int?
  Cost            Decimal? @db.Decimal(18, 9)
  impression      Int?
  status          Boolean  @default(true)
  RemainingAmount Int?
  AmountNull      Boolean?
}

model Publisher {
  id             String   @id @default(uuid())
  email          String?
  website_name   String?
  website_url    String?  @unique
  Tags           String[]
  keywords       String[]
  wallet_address String?
  status         String?  @default("ACTIVE")
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt
}

model Impression {
  id            String   @id @default(uuid())
  ad_id         String
  publisher_id  String
  impression    Int
  publisher_url String
  created_at    DateTime @default(now())

  @@unique([ad_id, publisher_id, publisher_url])
}

model Click {
  id            String    @id @default(uuid())
  ad_id         String
  publisher_id  String
  publisher_url String
  processed     Boolean   @default(false)
  claimed       Boolean   @default(false)
  claimed_at    DateTime?
  created_at    DateTime  @default(now())
  calculated    Boolean   @default(false)
  claimable_amount BigInt   @default(0)
}

model CLickEarningRecord {
  id               Int      @id @default(autoincrement())
  publisher_id     String
  ad_id            String
  claimable_amount BigInt   
  claimed          Boolean  @default(false)
  updated_at       DateTime @updatedAt

  @@unique([publisher_id, ad_id])
}

model EarningsRecord {
  id                String    @id @default(uuid())
  publisher_wallet  String
  ad_id             String
  claimable_amount  Int
  settled           Boolean   @default(false)
  settled_at        DateTime?
  created_at        DateTime  @default(now())
  advertiser_wallet String
  updated_at        DateTime  @default(now())

  @@unique([publisher_wallet, ad_id])
}

model WithdrawalRecord {
  id               String    @id
  publisher_wallet String
  tx_signature     String?
  total_amount     Int
  ad_ids           String[]
  status           String    @default("PENDING")
  created_at       DateTime  @default(now())
  confirmed_at     DateTime?
}

model Conversion {
  id         String   @id @default(uuid())
  ad_id      String
  revenue    Decimal
  type       String   @default("purchase")
  created_at DateTime @default(now())
}
